# ===========================================================================
# Immersity Deployment - Environment Variables
# ===========================================================================
# Copy this file to .env and update with your values
# Command: cp env.example .env

# Domain name (used for Let's Encrypt and routing)
DOMAIN=yourdomain.edu

# Timezone
TZ=America/Chicago

# Let's Encrypt email (for certificate expiration notices)
ACME_EMAIL=admin@yourdomain.edu








