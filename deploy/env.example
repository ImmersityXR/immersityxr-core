# ===========================================================================
# Immersity Deployment - Environment Variables
# ===========================================================================
# Copy this file to .env and update with your values
# Command: cp env.example .env

# Domain name (used for Let's Encrypt and routing)
DOMAIN=yourdomain.edu

# Timezone
TZ=America/Chicago

# Let's Encrypt email (for certificate expiration notices)
ACME_EMAIL=admin@yourdomain.edu

# ===========================================================================
# Relay server security
# ===========================================================================
# Origins allowed to connect to the relay (Socket.IO CORS), space-separated,
# in host:port form. Include the build server domain and, if you deploy the
# portal, the portal domain.
RELAY_ORIGINS=https://yourdomain.edu:443

# Shared secret VR clients must present to connect to the relay
# (append &auth=<value> to client launch URLs; the portal sends it
# automatically when VUE_APP_VR_AUTH_TOKEN is set).
# Leave empty to allow unauthenticated clients (NOT recommended).
# NOTE: enforcement requires a relay image with auth support - build it
# from a local checkout: docker compose build immersity-relay
RELAY_CLIENT_SECRET=

# Shared secret for the relay /admin diagnostics dashboard.
# With auth-capable relay images, /admin rejects ALL connections while
# this is empty.
RELAY_ADMIN_SECRET=

# Path to a local checkout of immersity-relay (only needed to build the
# relay image from source)
RELAY_REPO_PATH=../immersity-relay

# ===========================================================================
# WebRTC voice/video (relay /rtc namespace)
# ===========================================================================
# STUN servers handed to WebRTC clients (space-separated). The default
# public Google STUN servers are used when left empty.
RTC_STUN_URLS=

# Optional TURN server for participants behind strict NATs (e.g. off-campus
# attendees). Leave empty to skip. Example: turn:turn.yourdomain.edu:3478
RTC_TURN_URL=
RTC_TURN_USERNAME=
RTC_TURN_CREDENTIAL=

# ===========================================================================
# Web Portal (optional) - see docs/PORTAL.md
# ===========================================================================
# Uncomment the line below to include the portal in `docker compose up`
# and `./deploy.sh`. The portal needs its own DNS records (PORTAL_DOMAIN
# and PORTAL_API_DOMAIN must both point at this server).
#COMPOSE_PROFILES=portal

# Where the user-facing portal is served
PORTAL_DOMAIN=portal.yourdomain.edu

# Where the portal REST API is served
PORTAL_API_DOMAIN=api.yourdomain.edu

# Path to your checkout of the immersity-portal repository
# (relative to this directory)
PORTAL_REPO_PATH=../immersity-portal

# Database credentials for the portal backend (choose strong values;
# the database runs inside the backend container and is not exposed)
PORTAL_MYSQL_DATABASE=immersity
PORTAL_MYSQL_USER=immersity
PORTAL_MYSQL_PASSWORD=
PORTAL_MYSQL_ROOT_PASSWORD=

# Initial portal admin account, created the first time the database is
# initialized (there is no default password)
PORTAL_ADMIN_EMAIL=admin@yourdomain.edu
PORTAL_ADMIN_PASSWORD=
